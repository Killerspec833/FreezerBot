# =============================================================================
# Freezerbot .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets — NEVER commit these
# ---------------------------------------------------------------------------
# keys.enc IS intentionally committed (AES-256 encrypted — safe in git)
# The passphrase lives on the USB stick only
config/.install_passphrase

# config/config.json IS committed as a template (all keys empty)
# Do NOT add config/config.json here — prepare_usb.sh copies it to the USB stick

# ---------------------------------------------------------------------------
# User data (lives on USB stick, not in repo)
# ---------------------------------------------------------------------------
data/
*.db
*.db-wal
*.db-shm

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# Install / update markers (written to USB stick at runtime)
# ---------------------------------------------------------------------------
.install_complete
.current_version

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# ---------------------------------------------------------------------------
# OS / editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
