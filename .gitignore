# =============================================================================
# Freezerbot .gitignore
# =============================================================================

# --- NEVER commit these ---
config/.install_passphrase   # the decryption key for keys.enc
config/config.json           # may contain decrypted API keys at runtime
data/inventory.db            # user's personal inventory data
data/*.db
data/*.db-wal
data/*.db-shm
logs/

# --- Runtime / temp ---
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.env
*.tmp
/tmp/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Install markers ---
.install_complete

# --- keys.enc IS committed (encrypted — safe to include) ---
# keys.enc  <-- intentionally NOT ignored
